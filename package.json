{
  "name": "lernapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "content:extract": "node ./scripts/content/extract-unit1-candidates.mjs",
    "content:build": "node ./scripts/content/build-private-content.mjs",
    "content:check": "node ./scripts/content/check-private-content.mjs",
    "content:audit-coverage": "node ./scripts/content/audit-exercise-coverage.mjs",
    "pwa:cert": "node ./scripts/pwa/create-local-https-cert.mjs",
    "pwa:cert:check": "node ./scripts/pwa/check-local-https.mjs",
    "pwa:build": "node ./scripts/pwa/build-offline-web.mjs",
    "pwa:check": "node ./scripts/pwa/check-offline-export.mjs",
    "pwa:serve": "python ./scripts/serve-dist-preview.py --host 0.0.0.0 --port 8443",
    "pwa:update": "npm run pwa:cert && npm run pwa:cert:check && npm run pwa:build && npm run pwa:check && npm run pwa:serve",
    "repo:safety": "node ./scripts/content/check-public-repo.mjs",
    "qa": "npm run content:build && npm run content:check && npm run repo:safety && npm run typecheck && npm run lint",
    "qa:routes": "node ./scripts/qa/smoke-routes.mjs"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.8",
    "@shopify/react-native-skia": "2.2.12",
    "adm-zip": "^0.5.17",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "~0.1.9",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "pdfjs-dist": "^5.6.205",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
